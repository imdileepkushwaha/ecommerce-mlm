<%@ Master Language="C#" AutoEventWireup="true" CodeFile="Seller.Master.cs" Inherits="EcommerceWebsite.SellerMaster" %>

<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Merchant Hub</title>
    
    <!-- GLOBAL FONTS & ASSETS -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- SELLER GLOBAL DESIGN SYSTEM -->
    <link href="assets/css/seller.css?v=1.0" rel="stylesheet" />

    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body>
    <!-- Immediate Theme State Loader -->
    <script type="text/javascript">
        (function () {
            var savedTheme = localStorage.getItem("theme");
            if (savedTheme === "dark") {
                document.body.classList.add("dark-theme");
            }
        })();
    </script>
    <form id="form1" runat="server">
        
