        </aside>

        <!-- 2. PRIMARY DATA VIEWPORT -->
        <main class="content-panel">
            
            <!-- DYNAMIC TOP BAR HEADER (PREMIUM ATTACHMENT STRUCTURE) -->
            <header class="hdr-region">
                <button type="button" class="hdr-hamburger-btn" onclick="toggleSidebarMenu()" title="Toggle Menu">
                    <i class="fas fa-bars"></i>
                </button>
                
                <!-- Left: Global Search Wrapper -->
                <div class="hdr-search-box">
                    <i class="fas fa-search search-ico"></i>
                    <input type="text" id="globalNavSearch" placeholder="Search users, orders, sellers..." onkeyup="filterHubSearch()" autocomplete="off" />
                    <div id="searchAutoCompleteMenu" class="search-autocomplete-popup"></div>
                </div>

                <!-- Right: Action Anchors & Profile Pill -->
                <div class="hdr-actions-group">
                    <!-- Fullscreen Toggle -->
                    <button type="button" class="hdr-action-btn" onclick="toggleDashboardFullscreen()" title="Toggle Fullscreen">
                        <i class="fas fa-expand"></i>
                    </button>
                    <!-- Theme Toggle -->
                    <button type="button" class="hdr-action-btn" onclick="toggleDashboardTheme()" title="Toggle Theme">
                        <i class="far fa-moon" id="themeMoonIcon"></i>
                    </button>
                    
                    <!-- Bell Notifications with Red Dot Badge -->
                    <div class="hdr-bell-wrapper">
                        <button type="button" class="hdr-action-btn" onclick="toggleNotificationsMenu()" title="Notifications" style="position: relative;">
                            <i class="far fa-bell"></i>
                            <span class="bell-dot-indicator" id="bellDot" runat="server" ClientIDMode="Static"></span>
                        </button>
                        <!-- Notifications Popup -->
                        <div class="notifications-dropdown-popup" id="notificationsDropdown">
                            <div class="notif-dropdown-header">
                                <h3>Store Alerts</h3>
                                <button type="button" onclick="clearAllNotifications()">Clear All</button>
                            </div>
                            <div class="notif-dropdown-body" id="notifList">
                                <asp:Literal ID="litNotifList" runat="server"></asp:Literal>
                            </div>
                        </div>
                    </div>
                    
                    
                    <!-- Profile Capsule Pill -->
                    <div class="hdr-profile-capsule" onclick="toggleProfileDropdown()">
                        <div class="hdr-profile-avatar" id="avatarBgLetter" style="background: #8b5cf6; color: #fff; box-shadow: 0 2px 4px rgba(139, 92, 246, 0.2);">
                            <asp:Literal ID="litAvatarLetter" runat="server">M</asp:Literal>
                        </div>
                        <div class="hdr-profile-info">
                            <div class="hdr-profile-name">
                                <asp:Literal ID="litWelcomeName" runat="server">Merchant</asp:Literal>
                            </div>
                            <div class="hdr-profile-role">Store Merchant</div>
                        </div>
                        
                        <!-- Profile Dropdown popup menu -->
                        <div class="profile-dropdown-menu" id="profileDropdown">
                            <div class="profile-dropdown-header">
                                <div class="profile-dropdown-name">
                                    <asp:Literal ID="litDropdownName" runat="server">Merchant</asp:Literal>
                                </div>
                                <div class="profile-dropdown-email">
                                    <asp:Literal ID="litSellerEmail" runat="server"></asp:Literal>
                                </div>
                            </div>
                            <a href="Profile.aspx"><i class="fas fa-user-circle"></i> View Profile</a>
                            <a href="Settings.aspx"><i class="fas fa-sliders-h"></i> Settings</a>
                            <div class="profile-dropdown-divider"></div>
                            <asp:LinkButton ID="btnHdrLogout" runat="server" OnClick="btnLogout_Click" CausesValidation="false">
                                <i class="fas fa-sign-out-alt"></i> Sign Out
                            </asp:LinkButton>
                        </div>
                    </div>
                </div>
            </header>

            <!-- DYNAMIC PAGE CONTENT INJECTOR -->
            <div class="inner-content-wrapper">
                <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                </asp:ContentPlaceHolder>
            </div>

        </main>
    </form>

    <!-- Interactive Dashboards JS Engine -->
    <script type="text/javascript">
        // 1. Sidebar Active States
        document.addEventListener("DOMContentLoaded", function () {
            var path = window.location.pathname.split("/").pop().toLowerCase();
            if (!path) path = "dashboard.aspx";

            var links = document.querySelectorAll('.sb-nav a.nav-link');
            links.forEach(function (lnk) {
                lnk.classList.remove('active');
                var href = lnk.getAttribute('href');
                if (href && href.toLowerCase() === path) {
                    lnk.classList.add('active');
                }
            });
        });

        // 2. Fullscreen API
        function toggleDashboardFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(err => {
                    console.log("Error attempting to enable fullscreen:", err);
                });
            } else {
                document.exitFullscreen();
            }
        }

        // 3. Dark Theme System
        function toggleDashboardTheme() {
            const body = document.body;
            const moonIcon = document.getElementById("themeMoonIcon");
            body.classList.toggle("dark-theme");
            const isDark = body.classList.contains("dark-theme");
            localStorage.setItem("theme", isDark ? "dark" : "light");

            if (isDark) {
                moonIcon.className = "fas fa-sun";
            } else {
                moonIcon.className = "far fa-moon";
            }
        }

        // Initialize Theme Mode
        document.addEventListener("DOMContentLoaded", function() {
            const savedTheme = localStorage.getItem("theme");
            const moonIcon = document.getElementById("themeMoonIcon");
            if (savedTheme === "dark") {
                document.body.classList.add("dark-theme");
                if (moonIcon) moonIcon.className = "fas fa-sun";
            }
        });

        // 4. Notifications popover
        function toggleNotificationsMenu() {
            const dropdown = document.getElementById("notificationsDropdown");
            const profileDropdown = document.getElementById("profileDropdown");
            
            if (profileDropdown) profileDropdown.style.display = "none";
            
            if (dropdown.style.display === "block") {
                dropdown.style.display = "none";
            } else {
                dropdown.style.display = "block";
            }
        }

        function clearAllNotifications() {
            const notifList = document.getElementById("notifList");
            const bellDot = document.getElementById("bellDot");
            
            if (notifList) {
                notifList.innerHTML = `
                    <div style="padding: 20px; text-align: center; color: #94a3b8; font-size: 0.8rem;">
                        <i class="far fa-bell-slash" style="font-size: 1.5rem; margin-bottom: 8px; display: block; color: #cbd5e1;"></i>
                        No new alerts detected.
                    </div>
                `;
            }
            if (bellDot) bellDot.style.display = "none";
        }

        // 5. User Profile capsule popover
        function toggleProfileDropdown() {
            const dropdown = document.getElementById("profileDropdown");
            const notifDropdown = document.getElementById("notificationsDropdown");
            
            if (notifDropdown) notifDropdown.style.display = "none";
            
            if (dropdown.style.display === "block") {
                dropdown.style.display = "none";
            } else {
                dropdown.style.display = "block";
            }
        }

        // 6. Global Search dropdown list filtration
        function filterHubSearch() {
            const input = document.getElementById("globalNavSearch");
            const popup = document.getElementById("searchAutoCompleteMenu");
            const query = input.value.toLowerCase().trim();
            
            if (!query) {
                popup.style.display = "none";
                popup.innerHTML = "";
                return;
            }
            
            const navLinks = document.querySelectorAll(".sb-nav a.nav-link");
            let resultsHtml = "";
            let matchCount = 0;
            
            navLinks.forEach(lnk => {
                const text = lnk.textContent.replace(/[\s\n]+/g, " ").trim();
                const href = lnk.getAttribute("href");
                
                if (text.toLowerCase().includes(query)) {
                    const svgHtml = lnk.querySelector("svg") ? lnk.querySelector("svg").outerHTML : '<i class="fas fa-link"></i>';
                    resultsHtml += `
                        <a href="${href}" class="search-result-item">
                            ${svgHtml}
                            <span>${text}</span>
                        </a>
                    `;
                    matchCount++;
                }
            });
            
            if (matchCount > 0) {
                popup.innerHTML = resultsHtml;
                popup.style.display = "block";
            } else {
                popup.innerHTML = `
                    <div style="padding: 12px 14px; color: #94a3b8; font-size: 0.78rem; text-align: center;">
                        No matches for "${input.value}"
                    </div>
                `;
                popup.style.display = "block";
            }
        }

        // 7. Click Outside dropdown dismissals
        document.addEventListener("click", function(e) {
            const searchPopup = document.getElementById("searchAutoCompleteMenu");
            const notifPopup = document.getElementById("notificationsDropdown");
            const profilePopup = document.getElementById("profileDropdown");
            
            const searchBox = document.querySelector(".hdr-search-box");
            const bellWrapper = document.querySelector(".hdr-bell-wrapper");
            const profileCapsule = document.querySelector(".hdr-profile-capsule");
            
            if (searchPopup && searchBox && !searchBox.contains(e.target)) {
                searchPopup.style.display = "none";
            }
            if (notifPopup && bellWrapper && !bellWrapper.contains(e.target)) {
                notifPopup.style.display = "none";
            }
            if (profilePopup && profileCapsule && !profileCapsule.contains(e.target)) {
                profilePopup.style.display = "none";
            }
        });

        // 8. Toggle Sidebar Menu (Mobile)
        function toggleSidebarMenu() {
            var sidebar = document.getElementById("sidebarMenu");
            if (sidebar) {
                sidebar.classList.toggle("show-sidebar");
            }
        }
    </script>
</body>
</html>
